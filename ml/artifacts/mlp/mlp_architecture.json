      "out_features": 256
    },
    {
      "type": "ReLU"
    },
    {
      "type": "Dropout",
      "p": 0.3
    },
    {
      "type": "Linear",
      "in_features": 256,
      "out_features": 128
    },
    {
      "type": "ReLU"
    },
    {
      "type": "Dropout",
      "p": 0.2
    },
    {
      "type": "Linear",
      "in_features": 128,
      "out_features": 1
    },
    {
      "type": "Sigmoid"
    }
